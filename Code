#ifndef PROGRAMMES_GESTIONLISTES_H
#define PROGRAMMES_GESTIONLISTES_H

#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>

#define PETITE_BULLE 40
#define MOYENNE_BULLE 56
#define GRANDE_BULLE 80 // RAYON
#define LARGEUR_ECRAN 1800
#define HAUTEUR_ECRAN 800

//************************ STRUCTURES ************************//

// Structure générale
typedef struct position
{
    int x; // centre de l'objet ( axe x vers la droite)
    int y; // centre de l'objet (attention axe y est vers le bas!)
    float vx; //vitesse
    float vy;
    int largeur;
    int hauteur;
}Position;

// Structure Bulle
typedef struct bulle
{
    Position position; // position de la bulle
    int rayon; // il y a 3 tailles
    int objet; // numéro :  (arme (entier compris entre 1 et 4) , eclair (5), bonus (6), malus(7) ou rien (0))
    struct bulle *suivantBulle; // pointeur vers la structure bulle suivante
}Bulle;

//Les obstacles présents dans la zone de jeu ne seront pas alloués dynamiquement mais seront stockés dans un tableau statique puisque leurs positions ne varient pas durant la partie.
// Structure Obstacle
typedef struct obstacle {
    Position position;
    struct obstacle *suivant;
} Obstacle;

// Structure Objet
typedef struct objet
{
    Position positionObjet; // position de l'objet
    int type; //  (arme (entier compris entre 1 et 4) , eclair (5), bonus (6), malus(7) ou rien (0))
    float duree_restante; // durée restante d'activation de l'objet
    struct objet *suivantObjet; // pointeur vers la structure objet suivante
}Objet;

// Structure Balle
typedef struct balle
{
    Position positionBalle; // position de la balle
    struct balle *suivantBalle; // pointeur vers la structure balle suivante
}Balle;


//***************************** FONCTIONS *************************//

Bulle *creerBulle(bool ApparitionDebutJeu, int niveau);
Bulle *ajouterBulle(Bulle **tete, Bulle *nouveau);
void ajouterBulleAleatoirement(int niveau);
void supprimerBulle( Bulle **tete, Bulle *bulle);
int supprimerListeBulle(Bulle **tete);
Balle *creerBalle();
Balle *ajouterBalle(Balle **tete, Balle *nouveau);
void supprimerBallesHorsZone(Balle **tete, Balle *balle);
int supprimerListeBalle(Balle **tete);
Objet *creerObjet(int niveau);
Objet *ajouterObjet(Objet **tete, Objet *nouveau);
void supprimerObjet(Objet **tete, Objet *objet);
int supprimerListeObjet(Objet **tete);
bool listeVide();

#endif

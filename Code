void rebondBulleObstacle(Bulle *bulle, Obstacle *obstacle) {
    int diff_lh = (obstacle->position.largeur - obstacle->position.hauteur)/2;
    int dx = bulle->position.x - obstacle->position.x;
    int dy = bulle->position.y - obstacle->position.y;

    if (bulle->position.vy >= 0) {
        if (bulle->position.vx >= 0) { // vx >= 0 et vy >= 0
            if (dy/obstacle->position.hauteur >= dx/obstacle->position.largeur) {
                bulle->position.vx = -bulle->position.vx; // rebond en x
                bulle->position.x = 2*obstacle->position.x - obstacle->position.largeur -
                    2*bulle->rayon - bulle->position.x;
            } else {
                bulle->position.vy = -bulle->position.vy; // rebond en y
                bulle->position.y = 2*obstacle->position.y - obstacle->position.hauteur -
                    2*bulle->rayon - bulle->position.y;
            }
        } else {   // vy>=0 et vx<0
            if (dy/obstacle->position.hauteur >= -dx/obstacle->position.largeur) {
                bulle->position.vx = -bulle->position.vx; // rebond en x
                bulle->position.x = 2*obstacle->position.x + obstacle->position.largeur +
                    2*bulle->rayon - bulle->position.x;
            } else {
                bulle->position.vy = -bulle->position.vy; // rebond en y
                bulle->position.y = 2*obstacle->position.y - obstacle->position.hauteur -
                    2*bulle->rayon - bulle->position.y;
            }
        }
    } else {
        if (bulle->position.vx >= 0) { // vx >= 0 et vy < 0
            if (-dy/obstacle->position.hauteur >= dx/obstacle->position.largeur) {
                bulle->position.vx = -bulle->position.vx; // rebond en x
                bulle->position.x = 2*obstacle->position.x - obstacle->position.largeur -
                    2*bulle->rayon - bulle->position.x;
            } else {
                bulle->position.hauteur = 2*bulle->position.y - 2*obstacle->position.y - obstacle->position.hauteur;
                if (bulle->position.hauteur < bulle->rayon)
                {
                    bulle->position.vy = -bulle->position.vy; // rebond en y
                    bulle->position.y = 2*obstacle->position.y + obstacle->position.hauteur +
                        bulle->rayon - bulle->position.y;
                }
            }
        } else {   // vy>=0 et vx<0
            if (-dy/obstacle->position.hauteur >= -dx/obstacle->position.largeur) {
                bulle->position.vx = -bulle->position.vx; // rebond en x
                bulle->position.x = 2*obstacle->position.x + obstacle->position.largeur +
                    2*bulle->rayon - bulle->position.x;
            } else {
                bulle->position.vy = -bulle->position.vy; // rebond en y
                bulle->position.y = 2*obstacle->position.y + obstacle->position.hauteur +
                    2*bulle->rayon - bulle->position.y;
            }
        }
    }
}


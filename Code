#ifndef PROGRAMMES_GESTIONLISTES_H
#define PROGRAMMES_GESTIONLISTES_H

#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>

#define PETITE_BULLE 40
#define MOYENNE_BULLE 56
#define GRANDE_BULLE 80 // RAYON
#define LARGEUR_ECRAN 1800
#define HAUTEUR_ECRAN 800

//************************ STRUCTURES ************************//

// Structure générale
typedef struct position
{
    float x; // centre de l'objet ( axe x vers la droite)
    float y; // centre de l'objet (attention axe y est vers le bas!)
    float vx; //vitesse
    float vy;
    int largeur;
    int hauteur;
}Position;

typedef struct {
    Position position;
    int arme;
} Joueur;

typedef struct {
    int nb_tirs;
    int vitesse;
    bool vertical; //Si ce booléen vaut true, tous les tirs sont verticaux vers le haut. Sinon, il peut y avoir des tirs diagonaux. 
    bool bazuka;
} Arme;

// Structure Bulle
typedef struct bulle
{
    Position position; // position de la bulle
    int rayon; // il y a 3 tailles
    int objet; // numéro :  (arme (entier compris entre 1 et 4) , eclair (5), bonus (6), malus(7) ou rien (0))
    bool boule_de_feu // permet de savoir quel sprites afficher : si on combat le boss, ce booléen est à true
                       // et on affiche les sprites boules de feu. Sinon, on affiche les bulles dans afficherElements
    struct bulle *suivant; // pointeur vers la structure bulle suivante
}Bulle;

//Les obstacles présents dans la zone de jeu ne seront pas alloués dynamiquement mais seront stockés dans un tableau statique puisque leurs positions ne varient pas durant la partie.
// Structure Obstacle
typedef struct obstacle {
    Position position;
} Obstacle;

// Structure Objet
typedef struct objet
{
    Position position; // position de l'objet
    int type; //  (arme (entier compris entre 1 et 4) , eclair (5), bonus (6), malus(7) ou rien (0))
    float duree_restante; // durée restante d'activation de l'objet
    struct objet *suivant; // pointeur vers la structure objet suivante
}Objet;

// Structure Balle
typedef struct balle
{
    Position position; // position de la balle
    struct balle *suivant; // pointeur vers la structure balle suivante
}Balle;

typedef struct boss
{
    Position position; // position du boss
    int nb_tirs_recus; // nb_de_tirs_recus par le joueur
}Boss;


//***************************** FONCTIONS *************************//

Bulle *creerBulle();
Bulle *ajouterBulle(Bulle **tete, Bulle *nouveau);
void ajouterBulleAleatoirement(const int *niveau);
void supprimerBulle( Bulle **tete, Bulle *bulle);
int supprimerListeBulle(Bulle **tete);
Balle *creerBalle();
Balle *ajouterBalle(Balle **tete, Balle *nouveau);
void supprimerBallesHorsZone(Balle **tete, Balle *balle);
int supprimerListeBalle(Balle **tete);
Objet *creerObjet();
Objet *ajouterObjet(Objet **tete, Objet *nouveau);
void supprimerObjet(Objet **tete, Objet *objet);
int supprimerListeObjet(Objet **tete);
bool listeVide();


#endif

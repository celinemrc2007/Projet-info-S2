//Pour afficher un sprite, nous appelons cette fct avec le numéro du sprite à afficher et sa position passé en paramètre.
void afficherSprite (float x, float y, int numero_sprite) {
	BITMAP *image = images[numero_sprite];
	draw_sprite(screen, image,(int)(x - image->w / 2),(int)(y - image->h / 2));
}
void afficherNiveau(int niveau) {
	int w, h;
	/* Utilise la police bitmap par défaut d'Allegro */
	FONT *ma_police = font;

	while (!key[KEY_ESC]) {
		BITMAP *tmp = create_bitmap(200, 50);
		clear_to_color(screen, makecol(0, 0, 0));
		textprintf_ex(screen,font,50,750,makecol(255,255,255),-1,"NIVEAU : %d", niveau);
		stretch_sprite(screen, tmp, 100, 700, 400, 100);
		rest(120000);
	}
}

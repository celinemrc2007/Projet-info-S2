#ifndef PROGRAMMES_GESTIONLISTES_H
#define PROGRAMMES_GESTIONLISTES_H

#include <stdbool.h>
typedef struct {
    float x; // en pixels
    float y; // en pixels
    float vx; // en pixels/s
    float vy; // en pixels/s
    int largeur; // en pixels
    int hauteur; // en pixels
    bool actif;
} Position;

typedef struct bulle {
    Position position;
    int rayon;
    int objet;
    struct bulle *suivant;
} Bulle;

typedef struct obstacle {
    Position position;
    struct obstacle *suivant;
} Obstacle;



#endif

void supprimerBulle( Bulle **tete, Bulle *bulle) // n'importe laquelle dans la liste
{
    if (!listeVide())
    {
        Bulle *temporaire = *tete; // temporaire qui commence au debut de la liste
        if (temporaire->position.x == bulle->position.x && temporaire->position.y == bulle->position.y) //critere : si temporaire et bulle sont au meme endroit
        {
            *tete = temporaire->suivantBulle; // on fait pointer la tete sur la bulle suivante
            temporaire = NULL; // on rend l'adresse de la bulle pointée nulle pour supprimer la bulle
        }
        else
        {
            *tete = temporaire->suivantBulle; // on déplace la tete
        }
        free(temporaire); // liberation pour pouvoir avancer
    }
}

int supprimerListeBulle(Bulle **tete) // supression de la derniere bulle à la premiere
{
    while (!listeVide()) // tant qu'il y a une liste
    {
        // on libere toutes les bulles
        Bulle *temporaire = *tete; // pour parcourir la liste
        if ((*tete)->suivantBulle == NULL) //si on arrive à la fin de la liste
        {
            *tete = NULL; //on rend l'adresse de la bulle pointée nulle
        }
        else
        {
            *tete = temporaire->suivantBulle; // on avance dans la liste
        }
        free(temporaire); // liberation pour pouvoir avancer
    }
    return 1; // la liste est vide
}



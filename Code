Bulle *creerBulle(bool ApparitionDebutJeu, int niveau)
{
    Bulle *bulle = malloc(sizeof(Bulle)); // allocation dynamique
    if (bulle == NULL)
    {
        printf("Erreur allocation memoire.");
        exit(1);
    }
    switch (niveau)
    {
        case 1: bulle->objet = rand () % 1;  // Toutes les bulles sont vides.
        bulle->position.vx = rand() % 150 - 75;
        bulle->position.vy = rand() % 150 - 75;
        break;
        case 2: bulle->objet = rand () % 2; // Ajout d'une nouvelle arme
        //plus le niveau augmente, plus la vitesse augmente
        break;
        case 3: bulle->objet = rand () % 4; // Ajout d'une nouvelle arme et de l'éclair
        break;
        case 4: bulle->objet = rand () % 5; // Ajout d'une nouvelle arme 
        break;
        case 5: bulle->objet = rand () % 8; // Ajout d'une nouvelle arme, d'un bonus et d'un malus (8 cas posibles dont 7 objets diférents)
        break;
    }

    bulle->rayon = 1 + rand()%3 ; // taille aléatoire pour un nombre entre 1, 2, 3
    switch (bulle->rayon)
    {
        case 1: bulle->position.largeur = bulle->position.hauteur = 2*PETITE_BULLE; // rayon petite bulle : 40 pixel
        break;
        case 2: bulle->position.largeur = bulle->position.hauteur = 2*MOYENNE_BULLE; // rayon moyenne bulle : 56 pixel
        break;
        case 3: bulle->position.largeur = bulle->position.hauteur = 2*GRANDE_BULLE; // rayon grande bulle : 80 pixel
        break;
    }

    switch (ApparitionDebutJeu)
    {
        case TRUE: // bulles apparaissent partout dans le jeu
        bulle->position.x = bulle->rayon + rand()%(LARGEUR_ECRAN-bulle->rayon-(bulle->rayon)+1); // position x entre 0+rayon (min) et 1200-rayon (max)
        bulle->position.y = bulle->rayon + rand()%(500-bulle->rayon)-(bulle->rayon)+1; // position y entre 0+rayon (min) et 500-rayon (max)(elles n'apparaissent pas jusqu'en bas de l'écran pour des raisons de jouabilité
        break;
        case FALSE: // bulles apparaissent que sur les bords
        bulle->position.x = (bulle->rayon) | (LARGEUR_ECRAN-bulle->rayon); // sur les bors à gauche ou à droite
        bulle->position.y = bulle->rayon + rand()%(500-bulle->rayon)-(bulle->rayon)+1; // position y entre 0+rayon (min) et 500-rayon (max)(elles n'apparaissent pas jusqu'en bas de l'écran pour des raisons de jouabilité
        break;
    }

    bulle->suivantBulle = NULL;
    return bulle; // on retourne l'adresse de la bulle créée
}

Bulle *ajouterBulle(Bulle **tete, Bulle *nouveau) // ajout en début de liste
{
    //si liste vide
    if (listeVide())
    {
        *tete = nouveau; //tete contient l'adresse de nouveau, nouveau est à la fois premier et dernier
    }
    else
    {
        // ajout en début de liste
        nouveau->suivantBulle = *tete;
        *tete = nouveau; // nouvelle bulle devient la tete
    }
    return nouveau; // on retourne l'adresse de la nouvelle bulle
}

